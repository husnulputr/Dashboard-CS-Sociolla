shiny::runApp()
runApp()
runApp()
runApp()
# Load Data dari CSV dengan fallback ke data dummy
data_keluhan <- tryCatch({
read.csv("https://drive.google.com/uc?export=download&id=1wNEgmyGFImUjQPrfi0wm_tR0vilPwD5o")
}, error = function(e) {
# Jika gagal load, gunakan data dummy
message("Gagal memuat data: ", e)
data.frame(
Tanggal = Sys.Date() - 1:10,
Keluhan = sample(c("Harga tidak sesuai promosi", "Kurir tidak ramah", "Produk rusak"), 10, replace = TRUE),
Status = sample(c("Selesai", "Proses", "Belum Ditangani"), 10, replace = TRUE),
Agen = sample(c("Agen A", "Agen B", "Agen C"), 10, replace = TRUE),
Rating_CSAT = sample(1:5, 10, replace = TRUE),
NPS_Score = sample(-100:100, 10, replace = TRUE),
Waktu_Respon = sample(1:24, 10, replace = TRUE),
Persentase_Penyelesaian = runif(10, 0.5, 1),
Produk_Terkait = sample(c("makeup", "skincare", "haircare", "bodycare", "alat makeup"), 10, replace = TRUE)
)
})
# Data preprocessing hanya jika data berhasil dimuat
if (!is.null(data_keluhan)) {
data_keluhan$Tanggal <- as.Date(data_keluhan$Tanggal)
data_keluhan$Bulan <- format(data_keluhan$Tanggal, "%B")
data_keluhan$Bulan <- factor(data_keluhan$Bulan, levels = month.name)  # Ensure months are ordered
}
