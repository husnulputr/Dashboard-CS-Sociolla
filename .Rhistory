# Tab 2: Complaints Analytics (Updated)
tabItem(
tabName = "complaints_analytics",
fluidRow(
# Tampilkan data keluhan terbaru
box(
title = "Latest Complaints",
status = "info",
solidHeader = TRUE,
collapsible = TRUE,
width = 12,
